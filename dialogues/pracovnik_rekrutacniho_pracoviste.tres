nodes = {
&"0_1": {
"link": &"1_1",
"offset": Vector2(-1180, -260),
"start_id": "START"
},
&"0_2": {
"link": &"1_5",
"offset": Vector2(-880, 240),
"start_id": "FINISHED"
},
&"0_3": {
"link": &"1_8",
"offset": Vector2(-848.1022, 575.28174),
"start_id": "CONTINUE"
},
&"1_1": {
"dialogue": "Dobrý den. Koukám že už jste si svoje zelené přinesl. Normálně je to přestupek, když u nás nepracujete, nicméně budu to brát jako projev zájmu o vstup k nám. Naše firma je dost jiná než ty ostatní, to ostatně máte možnost vidět okolo mě.",
"offset": Vector2(-940, -260),
"options": {
0: {
"condition": {},
"link": &"1_2",
"text": "Co se stalo?"
},
1: {
"condition": {},
"link": &"1_6",
"text": "Rád bych tušil/a jak se tahle hra ovládá."
}
},
"size": Vector2(300, 344),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/dobry_den.mp3"
},
&"1_10": {
"dialogue": "No dobře... [E] přepne načítání dialogu. [W], [A], [S] a [D] se pohybuješ, jako ve všech normálních hrách. Levým myšítkem střílíš, kolečkem na myši přepínáš předměty v hotbaru. [I] zapne inventář. [Tab] hru stopne. Pokud narzíte na předměty nebo osoby, se kterými lze interagovat, jde to klávesou [E]. Poživatelné předměty z hotbaru lze konzumovat klávesou [Q]. A to je asi vše.",
"offset": Vector2(-100, 440),
"options": {
0: {
"condition": {},
"link": "END",
"text": "Díky."
}
},
"size": Vector2(300.0005, 309),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/tutorial.mp3"
},
&"1_2": {
"dialogue": "Snažili jsme se naučit dokumenty potřebné na zápis trochu pořadové přípravy...aby se uměly alespoň narovnat do komínků, pochodovat a tak.",
"offset": Vector2(-180, -280),
"options": {
0: {
"condition": {},
"link": &"1_3",
"text": "Tak to nechápu kde je problém, moje papíry to doma umí."
}
},
"size": Vector2(300.00018, 309),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/poradovka_pro_dokumenty.mp3"
},
&"1_3": {
"dialogue": "Moc se s naší vizí neztotožnily, naučily se házet propisky a vzbouřily se. Nicméně hlavní schopností vojáka je přizpůsobit se, takže pokud máte zájem, budete se muset k pohovoru probojovat.",
"offset": Vector2(260, -280),
"options": {
0: {
"condition": {},
"link": &"1_4",
"text": "Nikdy jsem s papírem nebojoval..."
}
},
"size": Vector2(300.0005, 309),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/dokumenty_se_neztotoznily.mp3"
},
&"1_4": {
"dialogue": "Je to jednoduché. Stačí vám občaský průkaz a psací potřeby. Házejte je zkuste se trefit, když je podepíšete, zkrotnou. Mám tady nějakou propisku, zkuste to tou. Až je zlikvidujete, vraťte se za mnou.",
"offset": Vector2(660, -260),
"options": {
0: {
"condition": {},
"link": &"3_3",
"text": "Díky!"
},
1: {
"condition": {},
"link": &"1_7",
"text": "Ještě nějaké tipy?"
}
},
"size": Vector2(300.00037, 344),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/jak_na_dokumenty.mp3"
},
&"1_5": {
"dialogue": "Dobrá práce. Pohovor máte splněný, ale obávám se, že za svoji kariéru uvidíte ještě hodně záludných papírů. Občas jsou nebezpečnější než cokoliv jiného, zvlášť když na nich je váš podpis.",
"offset": Vector2(-640, 240),
"options": {
0: {
"condition": {},
"link": &"3_1",
"text": "Díky!"
}
},
"size": Vector2(300.00006, 308.99997),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/to_byla_dobra_prace.mp3"
},
&"1_6": {
"dialogue": "No dobře... [E] přepne načítání dialogu. [W], [A], [S] a [D] se pohybuješ, jako ve všech normálních hrách. Levým myšítkem střílíš, kolečkem na myši přepínáš předměty v hotbaru. [I] zapne inventář. [Tab] hru stopne. Pokud narzíte na předměty nebo osoby, se kterými lze interagovat, jde to klávesou [E]. Poživatelné předměty z hotbaru lze konzumovat klávesou [Q]. A pomocí [Shift] uděláš přískok. A to je asi vše.",
"offset": Vector2(-540, -60),
"options": {
0: {
"condition": {},
"link": &"1_2",
"text": "Tak zpátky k věci..."
}
},
"size": Vector2(300, 309.00006),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/tutorial.mp3"
},
&"1_7": {
"dialogue": "Jo! Málem bych zapoměl. Kdybys tu našel nějaký bago, ber ho. V armádě funguje jako prémiová měna.",
"offset": Vector2(1180, -80),
"options": {
0: {
"condition": {},
"link": &"3_3",
"text": "Dobře, jdu."
}
},
"size": Vector2(300, 309),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/sbirej_bago.mp3"
},
&"1_8": {
"dialogue": "Běžte vyčistit kancelář od dokumentů, až to bude hotové, vraťte se za mnou.",
"offset": Vector2(-560, 580),
"options": {
0: {
"condition": {},
"link": &"1_10",
"text": "Jak se hra ovládá?"
},
1: {
"condition": {},
"link": &"1_9",
"text": "Jdu"
}
},
"size": Vector2(300, 344.00006),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/vyridte_dokumenty.mp3"
},
&"1_9": {
"dialogue": "Kryju.",
"offset": Vector2(-20, 820),
"options": {
0: {
"condition": {},
"link": "END",
"text": ""
}
},
"size": Vector2(300.00024, 273.99988),
"speaker": 4,
"voice": "res://sound/levels/rekrutak/kryju.mp3"
},
&"3_1": {
"link": "END",
"offset": Vector2(-220, 340),
"signalValue": "level_finished"
},
