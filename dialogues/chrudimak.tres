},
&"1_1": {
"dialogue": "Tady jste! Hledáme vás celou věčnost, nevíte že tu máte být o 5 minut dřív?? Doufejme že alespoň ta hudba vyjde, máme nového zvukaře protože na nástupech pluku to moc nefungovalo",
"offset": Vector2(-80, -220),
"options": {
0: {
"condition": {},
"link": &"1_3",
"text": " Pardon, už se to nikdy nestane."
},
1: {
"condition": {},
"link": &"3_3",
"text": "No a, táhni si do Chrudimi!"
}
},
"size": Vector2(379.99997, 360.0003),
"speaker": 0,
"voice": "res://sound/levels/prisaha/chrudimak/o_5m_drive.mp3"
},
&"1_3": {
"dialogue": "Cílem zaměstnání je synchronizovat kroky s hudbou, levá noha (mezerník) by měla vždy došlápnout na buben. Pár chyb vám prominu, ale snažte se ať to vypadá, jinak to půjdete znovu.",
"offset": Vector2(480, -220),
"options": {
0: {
"condition": {},
"link": &"3_1",
"text": "Dobře, to zvládnu"
}
},
"size": Vector2(339.99933, 360.00006),
"speaker": 0,
"voice": "res://sound/levels/prisaha/chrudimak/cil_zamestnani.mp3"
},
&"1_4": {
"dialogue": "Tak to byl dobrý výkon. Matky pláčou, otcové a domácí mazlíčci také a mě nezbývá než vám popřát hodně štěstí ve vaší budoucí kariéře! ",
"offset": Vector2(0, -540),
"options": {
0: {
"condition": {},
"link": &"3_2",
"text": "Taky budu brečet"
},
1: {
"condition": {},
"link": &"3_2",
"text": "Chcete kapesník?"
}
},
"size": Vector2(300.0008, 344),
"speaker": 0,
"voice": "res://sound/levels/prisaha/chrudimak/dobry_vykon.mp3"
},
&"3_1": {
"link": "END",
"offset": Vector2(900, -200),
"signalValue": "play_game"
},
