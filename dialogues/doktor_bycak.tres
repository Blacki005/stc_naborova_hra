&"1_1": {
"dialogue": "Démoni...démoni...démoni...démoni...démoni...",
"offset": Vector2(301.22272, 140.5206),
"options": {
0: {
"condition": {},
"link": &"1_2",
"text": "Co se stalo?"
}
},
"size": Vector2(300, 309.00006),
"speaker": 1,
"voice": "res://sound/levels/nemocnice/dr_bycak/demoni.mp3"
},
&"1_2": {
"dialogue": "UNOBáci...přivezli jsme je sem na povinnou kastraci. A jeden z nich začal křičet, Liboreeee, nebo nějak tak to znělo. Vypadly pojistky a po nemocnici se začaly pohybovat přízraky Libora, který nikomu nedovolí je nahodit. Pojistky jsou navíc zamčené. Jeden klíč se tu válí někde v jihovýchodní části s druhým jsem viděl utíkat bezdomovce do severozápadní části objektu. Zkus najít klíč a nahodit je, jsi naše jediná naděje!",
"offset": Vector2(800, 140),
"options": {
0: {
"condition": {},
"link": &"1_3",
"text": "Jdu"
},
1: {
"condition": {},
"link": &"1_4",
"text": "Nemáte něco co by mi při hledání pomohlo? "
}
},
"size": Vector2(300.0001, 344),
"speaker": 1,
"voice": "res://sound/levels/nemocnice/dr_bycak/povinna_kastrace.mp3"
},
&"1_3": {
"dialogue": "Kryju",
"offset": Vector2(1193.2971, 194.33044),
"options": {
0: {
"condition": {},
"link": "END",
"text": ""
}
},
"size": Vector2(300.00125, 274),
"speaker": 1,
"voice": "res://sound/levels/nemocnice/dr_bycak/kryju.mp3"
},
&"1_4": {
"dialogue": "No...sice bych neměl, ale za trochu baga jsem ochotný ti prodat nějaké lékařské vybavení, co by ti mohlo pomoct odehnat Libora.",
"offset": Vector2(1164.8223, 586.9675),
"options": {
0: {
"condition": {
"operator": 4,
"value1": "{{bago}}",
"value2": "1"
},
"link": &"3_1",
"text": "Ukaž, co máš."
},
1: {
"condition": {},
"link": "END",
"text": "Bohužel žádné bago nemám."
}
},
"size": Vector2(300.00064, 344.00003),
"speaker": 1,
"voice": "res://sound/levels/nemocnice/dr_bycak/za_bago_prodam_vybaveni.mp3"
},
&"3_1": {
"link": "END",
"offset": Vector2(1669.6921, 612.52075),
"signalValue": "display_shop"
}
}
