nodes = {
&"0_1": {
"link": &"1_1",
"offset": Vector2(-120, 100),
"start_id": "START"
},
&"1_1": {
"dialogue": "Chrrrrmpfff ",
"offset": Vector2(100, 60),
"options": {
0: {
"condition": {},
"link": &"1_2",
"text": "Dobrý den...co tu děláte?"
},
1: {
"condition": {},
"link": "END",
"text": "Fuj"
},
2: {
"condition": {},
"link": &"1_5",
"text": "Řekni mi svůj příběh"
}
},
"size": Vector2(300, 379.00003),
"speaker": 2,
"voice": "res://sound/levels/nemocnice/bezdomovec/chrrrmpppf.mp3"
},
&"1_2": {
"dialogue": "Viděl jsem že tady bylo otevřeno, tak sem sem šel hledat vajgly a drogy.",
"offset": Vector2(641.4811, 79.73221),
"options": {
0: {
"condition": {},
"link": &"1_3",
"text": "Dej sem ten klíč a vypadni!"
},
1: {
"condition": {},
"link": &"1_4",
"text": "Nemohl byste mi prosím věnovat ten klíč a opustit objekt? "
}
},
"size": Vector2(300.00003, 344.00003),
"speaker": 2,
"voice": "res://sound/levels/nemocnice/bezdomovec/sel_jsem_hledat_vajgly.mp3"
},
&"1_3": {
"dialogue": "No dobře, když to musí bejt...",
"offset": Vector2(1018.80615, 82.62192),
"options": {
0: {
"condition": {},
"link": &"3_2",
"text": "Dík"
}
},
"size": Vector2(300.00024, 309),
"speaker": 2,
"voice": "res://sound/levels/nemocnice/bezdomovec/kdyz_to_musi_bejt.mp3"
},
&"1_4": {
"dialogue": "To víš že jo, nehrozí. Radší mi běž sehnat nějaký injekce, už mi došly.",
"offset": Vector2(1000, 360),
"options": {
0: {
"condition": {
"operator": 0,
"value1": "{{has_injection}}",
"value2": "true"
},
"link": &"3_1",
"text": "Zrovna jsem jednu našel, tady ji máš! [bodnout injekcí]"
},
1: {
"condition": {},
"link": "END",
"text": "Dobře, jdu to najít. "
}
},
"size": Vector2(300.0006, 344),
"speaker": 2,
"voice": "res://sound/levels/nemocnice/bezdomovec/to_vis_ze_jo.mp3"
},
&"1_5": {
"dialogue": "No, když to chceš slyšet...začalo to na střední v Rumburku. Měli jsme mejdan jako kráva, ale přítelkyně otěhotněla a nějak to nevyšlo, špatný lidi a špatný místo. Pak jsem dělal v Praze u Krysy a taky chvíli v gastru, u Zlatýho Mloka. Ale z obojího jsem si odnesl jen další šrámy na duši. A od tý doby se to táhne, několikrát jsem seděl, ale vždycky jsem nějak zdrhnul.",
"offset": Vector2(320, 460),
"options": {
0: {
"condition": {},
"link": &"1_2",
"text": "Ok "
}
},
"size": Vector2(300, 309.00003),
"speaker": 2,
"voice": "res://sound/levels/nemocnice/bezdomovec/backstory.mp3"
},
&"3_1": {
"link": "END",
"offset": Vector2(1500, 460),
"signalValue": "die"
},
&"3_2": {
"link": "END",
"offset": Vector2(1401.7577, 152.08086),
"signalValue": "give_item"
}
}
