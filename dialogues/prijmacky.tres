nodes = {
&"0_1": {
"link": &"1_1",
"offset": Vector2(-140, 120),
"start_id": "START"
},
&"1_1": {
"dialogue": "Vítej na příjmačkách. Dřív se běhala dvanáctiminutovka, ale všichni už tak ztloustli, že jsme museli jít budoucnosti naproti a vymyslet něco, co není tak fatfóbní. Výsledek jsou srakety poháněné vlastním tukem. Je to super, protože dáváme šanci i lidem, které nezajímá sport. Zkus porazit roboty sestavené konkurenčním TUV ve tříkolovém závodě. Na trase je více cest, jeď tou nejkratší.",
"offset": Vector2(120, 120),
"options": {
0: {
"condition": {},
"link": &"3_1",
"text": "Jdeme na to!"
},
1: {
"condition": {},
"link": &"1_3",
"text": "Jak se to ovládá?"
},
2: {
"condition": {},
"link": &"1_5",
"text": "Co je TUV?"
}
},
"size": Vector2(300, 343.0001),
"speaker": ""
},
&"1_2": {
"dialogue": "Nějaké další dotazy?",
"offset": Vector2(980, 200),
"options": {
0: {
"condition": {},
"link": &"3_1",
"text": "Ne, jdeme na to."
},
1: {
"condition": {},
"link": &"1_3",
"text": "Jak se to ovládá?"
}
},
"size": Vector2(300.00024, 343),
"speaker": ""
},
&"1_3": {
"dialogue": "Raketa je jednoduchá - ovládá se klávesami [W], [A], [S], [D]. Mysleli jsme na všechny a designovali jsme je speciálně tak, aby bylo jednoduché je mačkat i tlustými prsty. Abychom dali obézním lidem ještě větší výhody, je raketa opatřena boostem, který rychle spaluje tuk a časem se obnovuje, ten použiješ mezerníkem.",
"offset": Vector2(540, 520),
"options": {
0: {
"condition": {},
"link": &"1_2",
"text": "Ok"
}
},
"size": Vector2(300, 273),
"speaker": ""
},
&"1_5": {
"dialogue": "TUV je konkurenční škola. Zkratka znamená Tady Určitě Vyletíš. Univerzita se zaměřuje na nabírání velkých počtů studentů a jejich následném masovém vyhazování, z čehož mají otrlejší členové TUV zpravidla velkou radost.",
"offset": Vector2(500, -80),
"options": {
0: {
"condition": {},
"link": &"1_2",
"text": "Ok"
}
},
"size": Vector2(300, 273),
"speaker": ""
},
&"3_1": {
"link": "END",
"offset": Vector2(1060, 20),
"signalValue": "start_race"
}
}
