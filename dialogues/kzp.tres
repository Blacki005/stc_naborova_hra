&"1_1": {
"dialogue": "Zdravím. Velení nám svěřilo CV-90 na testy a Grippeny na sešrotování, tak jsme to spojili dohormady.
Sedni do toho a zkus sesřelit alespoň 5 Grippenů aniž bys minul.",
"offset": Vector2(339.72076, 152.2567),
"options": {
0: {
"condition": {},
"link": &"1_2",
"text": "Co z toho budu mít?"
},
1: {
"condition": {},
"link": "END",
"text": "Jdu na to"
}
},
"size": Vector2(300.00027, 308),
"speaker": 3
},
&"1_2": {
"dialogue": "Tady nejsme na pirátské lodi, tady se rozkazy plní bez takových otázek. Ale abych tě motivoval, za každý sestřelený Grippen si na sebe vezmu část taktiky.",
"offset": Vector2(720, 160),
"options": {
0: {
"condition": {},
"link": "END",
"text": "Tak to beru"
}
},
"size": Vector2(300.00006, 273),
"speaker": 3
},
&"1_3": {
"dialogue": "Tahle prošla přímo skrz!",
"offset": Vector2(340, 520),
"options": {
0: {
"condition": {},
"link": "END",
"text": ""
}
},
"size": Vector2(300.00006, 240.00003),
"speaker": 3
},
&"1_4": {
"dialogue": "Na co koukáš? Soustřeď se na bitvu!",
"offset": Vector2(353.74854, 873.35333),
"options": {
0: {
"condition": {},
"link": "END",
"text": ""
}
},
"size": Vector2(300.00006, 240.00012),
"speaker": 3
},
&"1_5": {
"dialogue": "Výborně, vy budete postrach nepřátelských pilotů.",
"offset": Vector2(380, 1180),
"options": {
0: {
"condition": {},
"link": &"3_1",
"text": ""
}
},
"size": Vector2(300.00006, 240.00015),
